# Front door: https://service/...  (WebRTC needs secure context)
# /etc/hosts: 127.0.0.1 service
# Also: http://localhost/... (localhost is a secure context on HTTP)
{
	local_certs
}

(app) {
	encode gzip

	# More specific than /manage* — must come first
	handle_path /manage-api* {
		reverse_proxy manage-api:3121
	}

	# Частая ошибка: /api/manage/* → manage-api
	redir /api/manage* /manage-api{uri} 308

	# phone-server: HTTP API (demo session + health)
	handle /api/* {
		reverse_proxy phone-server:3101
	}
	# phone-server: WebSocket signaling (external)
	handle /ws/* {
		reverse_proxy phone-server:3102
	}

	# Softphone UI
	redir /softphone /softphone/ 308
	handle /softphone* {
		root * /srv
		try_files {path} /softphone/index.html
		file_server
	}

	# Manage UI
	redir /manage /manage/ 308
	handle /manage* {
		root * /srv
		try_files {path} /manage/index.html
		file_server
	}

	# Monitor
	redir /monitor /monitor/ 308
	handle_path /monitor/* {
		reverse_proxy monitor:3110
	}

	handle / {
		respond `Janus softphone stand

		/softphone/ — softphone UI
		/manage/ — manage UI
		/monitor/ — Janus monitor
		/manage-api/ — manage API
		/api/ — phone-server HTTP (session/health)
		/ws/ — phone-server WebSocket
		` 200
	}
}

service {
	tls internal
	import app
}

http://localhost {
	import app
}
