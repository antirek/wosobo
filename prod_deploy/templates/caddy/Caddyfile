# Front door: reverse-proxy only. Static → static:3140
# Generated by configure.sh — do not edit by hand; change install.env and re-run.

__CADDY_GLOBAL__

(app) {
	encode gzip

	handle_path /manage-api* {
		reverse_proxy manage-api:3121
	}

	redir /api/manage* /manage-api{uri} 308

	handle /api/* {
		reverse_proxy phone-server:3101
	}
	handle /ws/* {
		reverse_proxy phone-server:3102
	}

	redir /demo /demo/ 308
	handle_path /demo* {
		reverse_proxy softphone-demo:3130
	}

	handle /embed/softphone.js {
		reverse_proxy static:3140
	}
	handle /embed/softphone.js.map {
		reverse_proxy static:3140
	}
	handle /embed/softphone-headless.js {
		reverse_proxy static:3140
	}
	handle /embed/softphone-headless.js.map {
		reverse_proxy static:3140
	}
	redir /embed /demo/ 308
	redir /embed/ /demo/ 308
	redir /embed/demo.html /demo/ 308

	redir /softphone /demo/ 308
	redir /softphone/ /demo/ 308
	redir /softphone/* /demo/ 308

	redir /manage /manage/ 308
	handle /manage* {
		reverse_proxy static:3140
	}

	redir /monitor /monitor/ 308
	handle_path /monitor/* {
		basic_auth {
			__MONITOR_USER__ "__MONITOR_PASSWORD_HASH__"
		}
		reverse_proxy monitor:3110
	}

	handle / {
		respond `Wosobo softphone stand

		/demo/ — host-backend softphone demo
		/embed/softphone.js — embed widget
		/embed/softphone-headless.js — headless API
		/manage/ — manage UI
		/monitor/ — Janus monitor
		/manage-api/ — manage API
		/api/ — phone-server HTTP
		/ws/ — phone-server WebSocket
		` 200
	}
}

