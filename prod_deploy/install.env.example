# Server-specific settings for production install.
# Copy and edit, then run configure:
#
#   cp install.env.example install.env
#   $EDITOR install.env
#   ./configure.sh
#
# Generated outputs: .env, caddy/Caddyfile, janus/*.jcfg

# ─── Required ───────────────────────────────────────────────────────────────

# Public DNS name of this host (browser HTTPS / WSS). Softphone needs a secure context.
DOMAIN=softphone.example.com

# Public (or DNAT) IPv4 that the external SIP PBX uses to send RTP toward Janus.
# Must be reachable from the PBX; UDP JANUS_RTP_* must be forwarded to this host.
PUBLIC_IP=203.0.113.10

# ─── TLS (Caddy) ─────────────────────────────────────────────────────────────

# internal — self-signed (tls internal); browser warning once
# auto     — Let's Encrypt (domain must resolve to this server on :80/:443)
# off      — HTTP only (getUserMedia usually broken except localhost)
TLS_MODE=auto

# Used when TLS_MODE=auto (ACME account email)
TLS_EMAIL=admin@example.com

# ─── Secrets (empty = auto-generate on configure) ────────────────────────────

# Bearer token for manage-api / softphone-demo mint
MANAGE_API_TOKEN=

# Shared secret phone-server ↔ manage-api (X-Internal-Token)
INTERNAL_TOKEN=

# Janus Admin API secret (monitor)
JANUS_ADMIN_SECRET=

# ─── Images / ports ──────────────────────────────────────────────────────────

WOSOBO_IMAGE=antirek/wosobo:0.0.2
CADDY_IMAGE=caddy:2.8-alpine

HTTP_PORT=80
HTTPS_PORT=443

# WebRTC media UDP range (host publish + Janus sip plugin). Forward on firewall.
JANUS_RTP_START=20000
JANUS_RTP_END=20100

# Janus SIP: behind_nat (true/false). true if Contact must look public toward PBX.
JANUS_BEHIND_NAT=false

# ─── App ─────────────────────────────────────────────────────────────────────

# Extra CORS origins (comma-separated), e.g. https://app.example.com
# Primary origin https://DOMAIN is always included.
CORS_EXTRA=

ABSENT_ANNOUNCE_MAX_SEC=30
CALL_CDR_TTL_SEC=172800
