general: {
	# IP в SIP SDP (c=), куда внешняя PBX шлёт RTP / media к Janus на этом хосте.
	# Обычно публичный (или DNAT) IP сервера, куда проброшены JANUS_RTP_* UDP.
	sdp_ip = "__PUBLIC_IP__"

	keepalive_interval = 120
	behind_nat = __JANUS_BEHIND_NAT__
	register_ttl = 3600
	rtp_port_range = "__JANUS_RTP_START__-__JANUS_RTP_END__"
	sip_timer_t1x64 = 32000
}
