# Copy to deploy/.env and edit before deploy:
#   cp deploy/.env.example deploy/.env

# --- image ---
WOSOBO_IMAGE=wosobo:latest
CADDY_IMAGE=caddy:2.8-alpine

# --- public HTTP(S) ---
HTTP_PORT=80
HTTPS_PORT=443
# Browser origins (comma-separated). Softphone needs HTTPS or localhost.
CORS_ORIGIN=https://service,http://localhost

# --- secrets (REQUIRED) ---
MANAGE_API_TOKEN=change-me-manage-token
INTERNAL_TOKEN=change-me-internal-token

# --- data / Janus ---
MONGODB_URI=mongodb://mongo:27017/janus_softphone
JANUS_WS_URL=ws://janus:8188
JANUS_ADMIN_URL=http://janus:7088/admin
JANUS_ADMIN_SECRET=janusoverlord
OPENAPI_SERVER_URL=/manage-api
ABSENT_ANNOUNCE_MAX_SEC=30
CALL_CDR_TTL_SEC=172800

# --- media ports (must match asterisk/rtp.conf + janus.plugin.sip.jcfg) ---
ASTERISK_SIP_PORT=5060
ASTERISK_RTP_START=10000
ASTERISK_RTP_END=10099
JANUS_RTP_START=20000
JANUS_RTP_END=20100
